# Local-only project context and environment-specific overrides.
# compose override on disk in this private working tree. Keep it listed
# literally so it stays ignored; the public mirror does not ship this file
# and .gitignore is excluded from the sync, so the leaky name stays local.
CLAUDE.md
docker-compose.*.local.yml

# Model weights (download on deploy)
data/models/**/*.pt
data/models/**/*.pth
data/models/**/*.onnx
data/models/**/*.gguf
data/models/**/*.safetensors
data/models/**/*.bin
data/models/**/*.h5
data/models/**/*.msgpack

# NLP models (full HuggingFace downloads, ~3.4GB)
data/models/nlp/

# Datasets (too large for git)
data/datasets/
data/rag/*.csv
data/rag/*.json

# Training outputs (generated, regenerable)
training/output*/
training/checkpoints*/
training/*.log
unsloth_compiled_cache/

