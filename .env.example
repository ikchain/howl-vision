# =============================================================================
# Howl Vision — Environment Variables
# Copy to .env and adjust values for your environment
# =============================================================================

# -- Ollama (shared, already running) --
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:e4b

# -- Backend (FastAPI) --
BACKEND_HOST=0.0.0.0
BACKEND_PORT=20001
BACKEND_LOG_LEVEL=info
BACKEND_CORS_ORIGINS=http://localhost:20000

# -- Vision Service --
VISION_HOST=0.0.0.0
VISION_PORT=20002
VISION_MODELS_DIR=/app/models
# nnU-Net runs on CPU to save VRAM for Ollama
VISION_SEGMENTATION_DEVICE=cpu

# -- Qdrant (RAG vector DB) --
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=vet_cases

# -- Redis (cache + sessions) --
REDIS_HOST=redis
REDIS_PORT=6379

# -- PostgreSQL (conversations, patients, audit) --
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=howlvision
POSTGRES_USER=howl
POSTGRES_PASSWORD=changeme_in_production

# -- Frontend --
VITE_API_URL=http://localhost:20001

# -- Agent config --
AGENT_MAX_ITERATIONS=3
AGENT_VISION_CONFIDENCE_THRESHOLD=0.6
